generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  email     String   @unique
  password  String?
  name      String?
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  budgets            Budget[]
  expenses           Expense[]
  budgetMemberships  BudgetMember[]
  sentInvitations    BudgetInvitation[] @relation("InvitationSender")
  receivedInvitations BudgetInvitation[] @relation("InvitationRecipient")
  categories         Category[]

  @@map("users")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets  Budget[]
  expenses Expense[]

  @@index([userId])
  @@map("categories")
}

model Budget {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id")
  month       String   @db.VarChar(7)
  limitAmount Decimal  @map("limit_amount") @db.Decimal(12, 2)
  categoryId  String   @map("category_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  members     BudgetMember[]
  invitations BudgetInvitation[]

  @@unique([userId, month, categoryId])
  @@index([userId])
  @@index([month])
  @@index([categoryId])
  @@map("budgets")
}

model Expense {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id")
  budgetId    String   @map("budget_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  description String
  month       String   @db.VarChar(7)
  createdAt   DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([budgetId])
  @@index([month])
  @@index([categoryId])
  @@map("expenses")
}

model BudgetMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId  String   @map("budget_id") @db.Uuid
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([budgetId, userId])
  @@index([userId])
  @@map("budget_members")
}

model BudgetInvitation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId         String   @map("budget_id") @db.Uuid
  email            String
  invitedByUserId  String   @map("invited_by_user_id")
  invitedUserId    String?  @map("invited_user_id")
  status           String   @default("PENDING") @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")
  acceptedAt       DateTime? @map("accepted_at")

  budget      Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  invitedBy   User   @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedUser User?  @relation("InvitationRecipient", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([email])
  @@index([status])
  @@index([invitedUserId])
  @@map("budget_invitations")
}